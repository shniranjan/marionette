# Marionette — environment variables
# Copy to .env and fill in your key

# Access key for web UI (required in production, optional in dev)
MARIONETTE_KEY=change-me

# Comma-separated list for key rotation: MARIONETTE_KEY=key1,key2
# An empty value disables auth entirely (dev only)

# Directory for docker-compose stack files
MARIONETTE_STACKS_DIR=/stacks

# SQLite audit log database path (persistent across restarts)
MARIONETTE_DB_PATH=/data/marionette.db

# Log level: trace, debug, info, warn, error
MARIONETTE_LOG_LEVEL=info
